{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "leo-feedback-mcp": {
      "command": "uv",
      "args": ["run", "--directory", "/Users/leonguyen/Desktop/leo-feedback-mcp", "leo-feedback-mcp"],
      "timeout": 180,
      "autoApprove": ["interactive_feedback"]
    },
    "dart": {
      "type": "stdio",
      "command": "dart mcp-server --experimental-mcp-server --force-roots-fallback",
      "env": {},
      "args": []
    },
    "memory-keeper": {
      "command": "npx",
      "args": ["-y", "mcp-memory-keeper"],
      "env": {
        "TOOL_PROFILE": "full"
      },
      "timeout": 60
    }
  }
}
