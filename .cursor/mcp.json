{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "leo-feedback-mcp": {
      "command": "uvx",
      "args": ["leo-feedback-mcp"],
      "timeout": 180,
      "autoApprove": ["interactive_feedback"]
    },
    "dart": {
      "type": "stdio",
      "command": "dart mcp-server --experimental-mcp-server --force-roots-fallback",
      "env": {},
      "args": []
    }
  }
}
